# Core RocketRide connection (from your RocketRide account/extension settings)
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=

# Nebius inference key, used by the llm_nebius node in rfq_pipeline.pipe
ROCKETRIDE_NEBIUS_KEY=

# Aliases of the existing Daytona / Neo4j / Butterbase credentials, re-exposed
# under the ROCKETRIDE_ prefix so ${ROCKETRIDE_*} substitution can reach them.
ROCKETRIDE_DAYTONA_KEY=
ROCKETRIDE_NEO4J_URI=
ROCKETRIDE_NEO4J_USER=
ROCKETRIDE_NEO4J_PASSWORD=
ROCKETRIDE_BUTTERBASE_KEY=
